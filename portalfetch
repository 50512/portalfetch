#!/bin/bash

SCRIPT_DIR=$(dirname "$(readlink -f "$0")")

if [[ -d "$SCRIPT_DIR/logos" && -f "$SCRIPT_DIR/quotes.txt" && -d "$SCRIPT_DIR/config" ]]; then
    # Dev environment
    ASSETS_DIR="$SCRIPT_DIR"
else
    # Prod environment
    ASSETS_DIR="/usr/local/share/portalfetch"
fi

SELECTED_LOGO=""
FASTFETCH_ARGS=()
PRINT_ALL_LINES=0

# Read positional arguments
while [[ "$#" -gt 0 ]]; do
    case $1 in
        -l|--logo)
            SELECTED_LOGO="$2"
            shift 2 # Next argument
            ;;
        -c|--config)
            CONFIG_FILE="$2"
            shift 2
            ;;
        --all-lines)
            PRINT_ALL_LINES=1
            shift
            ;;
        --)
            shift
            FASTFETCH_ARGS=("$@")
            break
            ;;
        *)
            echo "Unknown flag: $1"
            exit 1
            ;;
    esac
done

# Set dir variables
LOGO_DIR="$ASSETS_DIR/logos"
QUOTES_FILE="$ASSETS_DIR/quotes.txt"
if [[ ! -n "$CONFIG_FILE" ]]; then
    FASTFETCH_CONF="$ASSETS_DIR/config/default.jsonc"
else
    FASTFETCH_CONF="$CONFIG_FILE"
fi

# Choose a random logo or use selected logo of the flag
if [[ -n "$SELECTED_LOGO" ]]; then
    # If use flag
    CHOSEN_LOGO="$LOGO_DIR/$SELECTED_LOGO.txt"
    if [[ ! -f "$CHOSEN_LOGO" ]]; then
        echo "Error: The logo '$SELECTED_LOGO' doesn't exist $LOGO_DIR"
        exit 1
    fi
else
    # Use random logo
    LOGOS=("$LOGO_DIR"/*.txt)
    TOTAL_LOGOS=${#LOGOS[@]}

    if [[ $TOTAL_LOGOS -eq 0 ]]; then
        echo "Error: Not found files in $LOGO_DIR"
        exit 1
    fi

    RANDOM_INDEX=$((RANDOM % TOTAL_LOGOS))
    CHOSEN_LOGO="${LOGOS[$RANDOM_INDEX]}"
fi

# -------- DATA --------
# 1. Fetch system info invisibly (stripping colors so we can measure text length)
info_raw=$(fastfetch -c "$FASTFETCH_CONF" "${FASTFETCH_ARGS[@]}" | sed -r 's/\x1b\[[0-9;]*[a-zA-Z]//g' | expand)

# 2. Grab a random quote and wrap it to fit the box (max 42 chars wide)
quote=$(shuf -n 1 "$QUOTES_FILE")

TERM_COLS=$(tput cols 2>/dev/null || echo 99)
TERM_LINES=$(tput lines 2>/dev/null || echo 40)

# -------- CALC LAYOUT AND RENDER --------
# Data is fed via stdin using a tagged-line protocol so awk knows which
# section each line belongs to. Sections:
#   info_raw lines    -> prefixed with "S:"
#   quote lines       -> prefixed with "Q:"
#   CHOSEN_LOGO lines -> prefixed with "L:"
#
# All layout math (widths, heights, clamping) and all rendering happens inside
# awk — zero subprocesses during the render loop.

{
    while IFS= read -r line; do printf 'S:%s\n' "$line"; done <<< "$info_raw"
    while IFS= read -r line; do printf 'Q:%s\n' "$line"; done < <(echo "$quote" | fold -s -w 42)
    while IFS= read -r line; do printf 'L:%s\n' "$line"; done < "$CHOSEN_LOGO"
    # Force UTF-8 to correct count of chars
} | LC_ALL=C awk \
    -v term_cols="$TERM_COLS" \
    -v term_lines="$TERM_LINES" \
    -v print_all_lines="$PRINT_ALL_LINES" \
    -v orange="\033[38;5;214m" \
    -v nc="\033[0m" \
'
function display_width(string,   tmp, base_chars, cjk_count) {
    tmp = string
    cjk_count = gsub(/[\xE3-\xE9][\x80-\xBF][\x80-\xBF]/, "", tmp)
    gsub(/[\x80-\xBF]/, "", tmp)
    base_chars = length(tmp)
    return base_chars + (cjk_count * 2)
}

function pad(string, width, diff, i, vlen) {
    vlen = display_width(string)
    diff = width - vlen
    for (i = 0; i < diff; i++) string = string " "
    return string
}

function truncated(string, width,   out, i, char, vlen, char_vlen) {
    if (display_width(string) <= width) return string

    out = ""
    vlen = 0
    # Read char byte by byte
    for (i = 1; i <= length(string); i++) {
        char = substr(string, i, 1)

        # If is not a continuation byte
        if (char !~ /[\x80-\xBF]/) {
            # Asian character (Kanji/Kana)
            if (char ~ /[\xE3-\xE9]/) {
                char_vlen = 2
            } else {
                char_vlen = 1
            }
            # Check limit with this char
            if (vlen + char_vlen > width) {
                break
            }

            # Add char if there is visual space
            vlen += char_vlen
        }

        # Ensamble the char byte by byte
        out = out char
    }

    return out
}

function repeat(char, n, string, i) {
    string = ""
    for (i = 0; i < n; i++) string = string char
    return string
}

# -------- INPUT PARSING --------

{
    tag     = substr($0, 1, 2)
    content = substr($0, 3)

    if      (tag == "S:") { sys[++ns]  = content }
    else if (tag == "Q:") { quo[++nq]  = content }
    else if (tag == "L:") { logo[++nl] = content }
}

# -------- Layout + rendering --------

END {
    RIGHT_CONTENT = 46
    RIGHT_TOTAL   = 51
    LEFT_HARD_MAX = 75
    LEFT_HARD_MIN = 30

    HEADER_1 = "Forms FORM-29827281-12:"
    HEADER_2 = "Fetch Assessment Report"

# -------- CALC LEFT WIDTH --------
    max_w = length(HEADER_1)
    if (length(HEADER_2) > max_w) max_w = length(HEADER_2)
    for (i = 1; i <= ns; i++) {
        w = display_width(sys[i])
        if (w > max_w) max_w = w
    }

    left_w = max_w
    if (left_w > LEFT_HARD_MAX)                   left_w = LEFT_HARD_MAX
    if (left_w > term_cols - RIGHT_TOTAL - 4)     left_w = term_cols - RIGHT_TOTAL - 4
    if (left_w < LEFT_HARD_MIN)                   left_w = LEFT_HARD_MIN

    frame_w = left_w + RIGHT_CONTENT + 7

    # -------- CALC TOTAL LINES --------
    left_lines  = ns + 2
    right_lines = 6 + nl
    total = (left_lines > right_lines) ? left_lines : right_lines

    if (print_all_lines == 0) {
        max_lines = term_lines - 3
        if (total > max_lines) total = max_lines
    }

    # -------- RENDER -------
    border = repeat("-", frame_w)
    div    = repeat("-", RIGHT_CONTENT + 2)

    printf "%s%s%s\n", orange, border, nc

    for (i = 0; i < total; i++) {

        # Left pane
        if      (i == 0)      left = HEADER_1
        else if (i == 1)      left = HEADER_2
        else if (i - 2 < ns)  left = sys[i - 1]
        else                  left = ""

        left_cell = pad(truncated(left, left_w), left_w)

        # Right pane
        if      (i < 5 && i < nq)  right = quo[i + 1]
        else if (i < 5)             right = ""
        else if (i == 5)            right = "DIVIDER"
        else if (i - 6 < nl)       right = logo[i - 5]
        else                        right = ""

        # Print row
        if (i == 5) {
            printf "%s| %s |%s|%s\n", orange, left_cell, div, nc
        } else {
            right_cell = pad(truncated(right, RIGHT_CONTENT), RIGHT_CONTENT)
            printf "%s| %s | %s |%s\n", orange, left_cell, right_cell, nc
        }
    }

    printf "%s%s%s\n", orange, border, nc
}
'