#!/bin/bash

SCRIPT_DIR=$(dirname "$(readlink -f "$0")")

if [[ -d "$SCRIPT_DIR/logos" && -f "$SCRIPT_DIR/quotes.txt" && -d "$SCRIPT_DIR/config" ]]; then
    # Dev environment
    ASSETS_DIR="$SCRIPT_DIR"
else
    # Prod environment
    ASSETS_DIR="/usr/local/share/portalfetch"
fi

# Set dir variables
LOGO_DIR="$ASSETS_DIR/logos"
QUOTES_FILE="$ASSETS_DIR/quotes.txt"
FASTFETCH_CONF="$ASSETS_DIR/config/fastfetch.jsonc"

SELECTED_LOGO=""

# Read positional arguments
while [[ "$#" -gt 0 ]]; do
    case $1 in
        -l|--logo)
            SELECTED_LOGO="$2"
            shift # Next argument
            ;;
        *)
            echo "Unknown flag: $1"
            exit 1
            ;;
    esac
    shift # Next
done

# Choose a random logo or use selected logo of the flag
if [[ -n "$SELECTED_LOGO" ]]; then
    # If use flag
    CHOSEN_LOGO="$LOGO_DIR/$SELECTED_LOGO.txt"
    if [[ ! -f "$CHOSEN_LOGO" ]]; then
        echo "Error: The logo '$SELECTED_LOGO' doesn't exist $LOGO_DIR"
        exit 1
    fi
else
    # Use random logo
    LOGOS=("$LOGO_DIR"/*.txt)
    TOTAL_LOGOS=${#LOGOS[@]}

    if [[ $TOTAL_LOGOS -eq 0 ]]; then
        echo "Error: Not found files in $LOGO_DIR"
        exit 1
    fi

    RANDOM_INDEX=$((RANDOM % TOTAL_LOGOS))
    CHOSEN_LOGO="${LOGOS[$RANDOM_INDEX]}"
fi

# Get real width of a string
visual_width() {
    echo -n "$1" | awk '{print length($0)}'
}

# Pads a string to exactly $2 visual columns.
pad_visual() {
    local str="$1"
    local target="$2"
    local vw
    vw=$(visual_width "$str")
    local spaces=$(( target - vw ))
    (( spaces < 0 )) && spaces=0
    printf "%s%*s" "$str" "$spaces" ""
}

# Trims a string to at most $2 visual columns.
truncate_visual() {
    local str="$1"
    local max="$2"
    echo -n "$str" | awk -v max="$max" '
    {
        out = ""; col = 0
        n = split($0, chars, "")
        for (i = 1; i <= n; i++) {
            col++
            if (col > max) break
            out = out chars[i]
        }
        printf "%s", out
    }'
}

# 1. Fetch system info invisibly (stripping colors so we can measure text length)
info_raw=$(fastfetch -c $FASTFETCH_CONF | sed -r 's/\x1b\[[0-9;]*[a-zA-Z]//g' | expand)
mapfile -t sys_info <<< "$info_raw"

# 2. Grab a random quote and wrap it to fit the box (max 42 chars wide)
quote=$(shuf -n 1 "$QUOTES_FILE")
mapfile -t quote_lines < <(echo "$quote" | fold -s -w 42)

# 3. The exact Aperture Science Logo
mapfile -t logo_lines < "$CHOSEN_LOGO"

# Right pane content width is fixed at 46 (+ divider special case uses 48 with no spaces).
RIGHT_CONTENT=46      # inner cols for right pane content
RIGHT_TOTAL=51        # right pane total cols (borders + spaces + content)

# Max left width: widest line in sys_info (measured in visual cols)
MAX_CONTENT_WIDTH=0
for line in "${sys_info[@]}"; do
    w=$(visual_width "$line")
    (( w > MAX_CONTENT_WIDTH )) && MAX_CONTENT_WIDTH=$w
done

HEADER_1="Forms FORM-29827281-12:"
HEADER_2="Fetch Assessment Report"

# Also consider header lines
for header in $HEADER_1 $HEADER_2; do
    w=$(visual_width "$header")
    (( w > MAX_CONTENT_WIDTH )) && MAX_CONTENT_WIDTH=$w
done

TERM_COLS=$(tput cols 2>/dev/null || echo 99)
TERM_LINES=$(tput lines 2>/dev/null || echo 40)

LEFT_MAX_BY_TERM=$(( TERM_COLS - RIGHT_TOTAL - 4 ))
LEFT_HARD_MAX=60
LEFT_HARD_MIN=30

LEFT_WIDTH=$MAX_CONTENT_WIDTH
(( LEFT_WIDTH > LEFT_HARD_MAX     )) && LEFT_WIDTH=$LEFT_HARD_MAX
(( LEFT_WIDTH > LEFT_MAX_BY_TERM  )) && LEFT_WIDTH=$LEFT_MAX_BY_TERM
(( LEFT_WIDTH < LEFT_HARD_MIN     )) && LEFT_WIDTH=$LEFT_HARD_MIN

# Total frame width: "| " + LEFT + " | " + RIGHT_CONTENT + " |"
#   borders/separators: | (1) + space (1) + LEFT_WIDTH + space (1) + | (1) + space (1) + RIGHT_CONTENT + space (1) + | (1) = LEFT_WIDTH + 7 + RIGHT_CONTENT
FRAME_WIDTH=$(( LEFT_WIDTH + RIGHT_CONTENT + 7 ))

# Total lines: 3 header rows + sys_info rows
LEFT_CONTENT_LINES=$(( ${#sys_info[@]} + 2 ))

# Right pane lines: quotes (max 5) + 1 divider + logo lines
RIGHT_CONTENT_LINES=$(( 6 + ${#logo_lines[@]} ))

# Total lines is the taller of the two panes
TOTAL_LINES=$(( LEFT_CONTENT_LINES > RIGHT_CONTENT_LINES ? LEFT_CONTENT_LINES : RIGHT_CONTENT_LINES ))

# Clamp to terminal height (leave 2 rows for top/bottom borders + 1 breathing room)
MAX_LINES=$(( TERM_LINES - 3 ))
(( TOTAL_LINES > MAX_LINES )) && TOTAL_LINES=$MAX_LINES

# Portal Amber Color
ORANGE='\033[38;5;214m'
NC='\033[0m'

# Top border (exact frame width)
BORDER=$(printf '%*s' "$FRAME_WIDTH" '' | tr ' ' '-')
echo -e "${ORANGE}${BORDER}${NC}"

for (( i=0; i<TOTAL_LINES; i++ )); do

    # --- LEFT PANE ---
    if   (( i == 0 )); then left=$HEADER_1
    elif (( i == 1 )); then left=$HEADER_2
    elif (( i >= 2 && i-2 < ${#sys_info[@]} )); then left="${sys_info[$((i-2))]}"
    else left=""
    fi

    left=$(truncate_visual "$left" "$LEFT_WIDTH")
    left_padded=$(pad_visual "$left" "$LEFT_WIDTH")

    # --- RIGHT PANE ---
    if   (( i < 5 && i < ${#quote_lines[@]} )); then right="${quote_lines[$i]}"
    elif (( i < 5 ));                           then right=""
    elif (( i == 5 ));                          then right="DIVIDER"
    else
        logo_idx=$(( i - 6 ))
        if (( logo_idx < ${#logo_lines[@]} ));  then right="${logo_lines[$logo_idx]}"
        else right=""
        fi
    fi

    # Render line — divider row has special padding (fills full inner width without spaces)
    if (( i == 5 )); then
        # Divider spans the full right inner width + the 2 spaces that normally frame content
        div_width=$(( RIGHT_CONTENT + 2 ))
        div_line=$(printf '%*s' "$div_width" '' | tr ' ' '-')
        echo -e "${ORANGE}| ${left_padded} |${div_line}|${NC}"
    else
        right=$(truncate_visual "$right" "$RIGHT_CONTENT")
        right_padded=$(pad_visual "$right" "$RIGHT_CONTENT")
        echo -e "${ORANGE}| ${left_padded} | ${right_padded} |${NC}"
    fi
done

# Bottom border
echo -e "${ORANGE}${BORDER}${NC}"