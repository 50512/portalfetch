#!/bin/bash

SCRIPT_DIR=$(dirname "$(readlink -f "$0")")

if [[ -d "$SCRIPT_DIR/logos" && -f "$SCRIPT_DIR/quotes.txt" && -d "$SCRIPT_DIR/config" ]]; then
    # Dev environment
    ASSETS_DIR="$SCRIPT_DIR"
else
    # Prod environment
    ASSETS_DIR="/usr/local/share/portalfetch"
fi

# Set dir variables
LOGO_DIR="$ASSETS_DIR/logos"
QUOTES_FILE="$ASSETS_DIR/quotes.txt"
FASTFETCH_CONF="$ASSETS_DIR/config/fastfetch.jsonc"

SELECTED_LOGO=""

# Read positional arguments
while [[ "$#" -gt 0 ]]; do
    case $1 in
        -l|--logo)
            SELECTED_LOGO="$2"
            shift # Next argument
            ;;
        *)
            echo "Parámetro desconocido: $1"
            exit 1
            ;;
    esac
    shift # Next
done

# Choose a random logo or use selected logo of the flag
if [[ -n "$SELECTED_LOGO" ]]; then
    # If use flag
    CHOSEN_LOGO="$LOGO_DIR/$SELECTED_LOGO.txt"
    if [[ ! -f "$CHOSEN_LOGO" ]]; then
        echo "Error: The logo '$SELECTED_LOGO' doesn't exist $LOGO_DIR"
        exit 1
    fi
else
    # Use random logo
    LOGOS=("$LOGO_DIR"/*.txt)
    TOTAL_LOGOS=${#LOGOS[@]}

    if [[ $TOTAL_LOGOS -eq 0 ]]; then
        echo "Error: Not found files in $LOGO_DIR"
        exit 1
    fi

    RANDOM_INDEX=$((RANDOM % TOTAL_LOGOS))
    CHOSEN_LOGO="${LOGOS[$RANDOM_INDEX]}"
fi

# 1. Fetch system info invisibly (stripping colors so we can measure text length)
info_raw=$(fastfetch --logo none --pipe -c $FASTFETCH_CONF | sed -r 's/\x1b\[[0-9;]*[a-zA-Z]//g' | expand)
mapfile -t sys_info <<< "$info_raw"

# 2. Grab a random quote and wrap it to fit the box (max 42 chars wide)
quote=$(shuf -n 1 "$QUOTES_FILE")
mapfile -t quote_lines < <(echo "$quote" | fold -s -w 42)

# 3. The exact Aperture Science Logo
mapfile -t logo_lines < "$CHOSEN_LOGO"

# Portal Amber Color
ORANGE='\033[38;5;214m'
NC='\033[0m'

# Draw Top Border
echo -e "${ORANGE}---------------------------------------------------------------------------------------------------${NC}"

# Draw the 27 lines of the UI
for i in {0..26}; do
    
    # --- LEFT PANE (System Info) ---
    if [ $i -eq 0 ]; then
        left="Forms FORM-29827281-12:"
    elif [ $i -eq 1 ]; then
        left="Fetch Assessment Report"
    elif [ $i -eq 2 ]; then
        left=""
    elif [ $i -ge 3 ] && [ $((i-3)) -lt ${#sys_info[@]} ]; then
        left="${sys_info[$((i-3))]}"
    else
        left=""
    fi

    # Truncate to 46 chars and pad with spaces
    left=${left:0:46}
    printf -v left_padded "%-46s" "$left"

    # --- RIGHT PANE (Quotes & Logo) ---
    if [ $i -lt 5 ]; then
        if [ $i -lt ${#quote_lines[@]} ]; then
            right="${quote_lines[$i]}"
        else
            right=""
        fi
    elif [ $i -eq 5 ]; then
        # The inner divider
        right="------------------------------------------------"
    else
        logo_idx=$((i-6))
        if [ $logo_idx -lt ${#logo_lines[@]} ]; then
            right="${logo_lines[$logo_idx]}"
        else
            right=""
        fi
    fi

    # Format the borders
    right=${right:0:48}
    if [ $i -eq 5 ]; then
        printf -v right_padded "%-48s" "$right"
        echo -e "${ORANGE}| ${left_padded} |${right_padded}|${NC}"
    else
        printf -v right_padded "%-46s" "$right"
        echo -e "${ORANGE}| ${left_padded} | ${right_padded} |${NC}"
    fi
done

# Draw Bottom Border
echo -e "${ORANGE}---------------------------------------------------------------------------------------------------${NC}"
